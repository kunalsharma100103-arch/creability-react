Options -MultiViews
RewriteEngine On
RewriteBase /

# Let PHP API files execute directly (uploads, auth, CRUD endpoints)
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]

# Serve existing static files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else → index.html (React SPA handles /admin, /about, etc.)
RewriteRule ^ index.html [L]
